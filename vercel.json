{
    "version": 2,
    "builds": [
        {
            "src": "client/package.json",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "../server/public"
            }
        }
    ],
    "routes": [
        {
            "src": "(.*)",
            "dest": "/index.html"
        }
    ]
}